{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },

  "Identity": {
    "SecretKey": "xxx",
    "SessionDuration": 60, // minutes
    "Audiences": [ "xxx" ],
    "AdminUsers": [
      {
        "Email": "xxx",
        "Password": "xxx"
      }
    ]
  },

  "ConnectionStrings": {
    //"SqlServer": {
    //  "PIM": "Data Source=xxx,9999;Initial Catalog=regira_pim;User ID=xxx;Password=xxx;TrustServerCertificate=True",
    //  "Accounts": "Data Source=xxx,9999;Initial Catalog=regira_pim_accounts;User ID=xxx;Password=xxx;TrustServerCertificate=True"
    //},
    "Sqlite": {
      "PIM": "Data Source=xxx\\pim.db",
      "Accounts": "Data Source=XXX\\accounts.db"
    }
  }
}
