{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },

  "Identity": {
    "SecretKey": "xxx",
    "SessionDuration": 60, // minutes
    "Audiences": [ "xxx" ],
    "AdminUsers": [
      {
        "Email": "xxx",
        "Password": "xxx"
      }
    ],
    "DemoUsers": [
      {
        "Email": "demo@regira.com",
        "Password": "demo"
      }
    ]
  },

  "AllowedOrigins": [
    "http://localhost:5174",
    "http://localhost:5173",
    "https://pim.regira.com"
  ],

  "Regira": {
    // Get your license key at https://regira.com/licensing
    //"LicenseKey": "XXX"
  },

  "ConnectionStrings": {
    //"SqlServer": {
    //  "PIM": "Data Source=xxx,1433;Initial Catalog=regira_pim;User ID=xxx;Password=xxx;TrustServerCertificate=True",
    //  "Accounts": "Data Source=xxx,1433;Initial Catalog=regira_pim_accounts;User ID=xxx;Password=xxx;TrustServerCertificate=True"
    //},
    "Sqlite": {
      "PIM": "Data Source=pim.db",
      "Accounts": "Data Source=accounts.db"
    }
  }
}
